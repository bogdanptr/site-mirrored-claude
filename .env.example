# Sanity project configuration
# Find these in https://www.sanity.io/manage → your project
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production

# Write token (Editor permission) — ONLY needed to run the migration script.
# Create at: Sanity Manage → API → Tokens. Do NOT commit this value.
SANITY_WRITE_TOKEN=
