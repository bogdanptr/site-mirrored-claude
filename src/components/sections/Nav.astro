</style></div><div class="hide w-embed w-script"><script>
  document.addEventListener('DOMContentLoaded', function() {
    var navbar = document.querySelector('.navbar');
    if (!navbar) return;

    var activated = false;

    function activate() {
      if (activated || window.innerWidth < 992) return;
      activated = true;
      navbar.classList.add('is-solid');
    }

    window.addEventListener('scroll', function() {
      if (window.scrollY > 0) activate();
    }, { passive: true });

    navbar.addEventListener('mouseenter', activate);

    // Check on load in case page loaded scrolled down
    if (window.scrollY > 0) activate();
  });
</script></div></div>
