  window.addEventListener('load', () => {
    document.querySelectorAll('[data-nav-move-target]').forEach(target => {
      const key = target.getAttribute('data-nav-move-target');
      const itemToMove = document.querySelector(`[data-nav-move-item="${key}"]`);

      if (!itemToMove) return;

      const isCurrentPage = window.location.pathname === itemToMove.getAttribute('href');

      if (isCurrentPage) {
        target.querySelectorAll('.w-tab-link').forEach(tab => {
          tab.classList.remove('w--current');
        });
      }

      itemToMove.classList.remove('w--current', 'w-tab-link');

      // If a tab name is specified, set it so Webflow styling works
      const tabName = itemToMove.getAttribute('data-nav-move-tab');
      if (tabName) {
        itemToMove.setAttribute('data-w-tab', tabName);
        itemToMove.classList.add('w-tab-link');
      }

      // Insert at specific position, or append to end
      const position = parseInt(itemToMove.getAttribute('data-nav-move-position'));
      const children = target.children;

      if (!isNaN(position) && position < children.length) {
        target.insertBefore(itemToMove, children[position]);
      } else {
        target.appendChild(itemToMove);
      }
    });
  });
</script></div><div class="hide w-embed"><style>
