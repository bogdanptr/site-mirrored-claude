---
interface Link {
  href: string;
  label: string;
}
interface Props {
  title: string;
  titleColor?: "default" | "secondary";
  links: Link[];
  grid?: boolean;
}
const { title, titleColor = "default", links, grid = false } = Astro.props;
const titleClass = titleColor === "secondary" ? "eyebrow u-color-secondary" : "eyebrow";
const listClass = grid ? "u-grid cc-col-2 cc-gap-16 w-list-unstyled" : "u-d-flex cc-vertical cc-gap-16 w-list-unstyled";
---
<div class="footer_col">
  <div class="u-d-flex cc-vertical cc-gap-32">
    <div>
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 0 327 18" fill="none" class="envelope u-color-secondary">
        <path d="M326 17L309.994 0.999999L6.99382e-07 0.999986" stroke="currentColor" stroke-width="1" opacity="0.3"></path>
      </svg>
      <h3 class={titleClass}>{title}</h3>
    </div>
    <ul role="list" class={listClass}>
      {links.map((link) => (
        <li><a href={link.href} class="footer_links a-text-link">{link.label}</a></li>
      ))}
    </ul>
  </div>
</div>
