---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---
<li class="u-d-flex cc-vertical">
  <div class="u-d-flex cc-horizontal cc-left-center cc-gap-16">
    <svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 0 24 24" fill="none" class="u-icon cc-24 u-color-brand">
      <path d="M15 9.5L10.5 15L8.5 13M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="square"></path>
    </svg>
    <div class={`eyebrow ${className}`.trim()}><slot /></div>
  </div>
</li>
